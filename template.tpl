setup: |-
  const log = require('logToConsole');
  const JSON = require('JSON');

  const RequestHistory = [];

  mock('sendHttpRequest', function() {
    const url = arguments[0];
    const callback = arguments[1];
    const params = arguments[2];
    const body = arguments[3];

    log('sendHttpRequest', arguments);

    const respStatusCode = 200;
    const respHeaders = {};
    const respBody = {};
    callback(respStatusCode, respHeaders, respBody);

    RequestHistory.push({
      url: url,
      headers: params.headers,
      body: body,
    });
  });

  mock('setCookie', function() {});
  mock('getCookieValues', function() { return []; });


